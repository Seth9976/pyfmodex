{
    "version": 1,
    "functions": [
        {
            "id": "ak.wwise.waapi.getSchema",
            "restrict": [
                "userInterface",
                "commandLine"
            ],
            "seeAlso": [
                "ak.wwise.waapi.getFunctions",
                "ak.wwise.waapi.getTopics"
            ],
            "description": "Retrieves the JSON schema of a Waapi Function or Topic URI.",
            "argsSchema": {
                "type": "object",
                "properties": {
                    "uri": {
                        "type": "string",
                        "description": "Function or Topic URI. See \\ref ak_wwise_waapi_getfunctions and \\ref ak_wwise_waapi_gettopics to get the lists of functions and topics."
                    },
                    "includeExamples": {
                        "type": "boolean",
                        "description": "Include the examples provided in the schema. Default value is false."
                    }
                },
                "required": [
                    "uri"
                ],
                "additionalProperties": false
            },
            "resultSchema": {
                "type": "object",
                "properties": {
                    "argsSchema": {
                        "type": "object",
                        "description": "The argument schema. Only possible for functions.",
                        "properties": {},
                        "additionalProperties": true
                    },
                    "optionsSchema": {
                        "type": "object",
                        "description": "The option schema.",
                        "properties": {},
                        "additionalProperties": true
                    },
                    "resultSchema": {
                        "type": "object",
                        "description": "The result schema. Only possible for functions.",
                        "properties": {},
                        "additionalProperties": true
                    },
                    "publishSchema": {
                        "type": "object",
                        "description": "The publish schema. Only possible for topics.",
                        "properties": {},
                        "additionalProperties": true
                    },
                    "description": {
                        "type": "string",
                        "description": "The description of the function or topic."
                    },
					"examples": {
						"type": "array",
                        "description": "The examples provided in the schema.",
						"items" : {
							"type": "object",
							"description": "The example.",
							"properties": {},
							"additionalProperties": true
						}
					}
                },
                "additionalProperties": false
            },
            "optionsSchema": {
                "type": "object",
                "properties": {},
                "additionalProperties": false
            },
            "examples": []
        }
    ],
    "topics": [],
    "validators": []
}