{
    "version": 1,
    "functions": [
        {
            "id": "ak.wwise.core.workUnit.unload",
            "restrict": [
                "userInterface",
                "commandLine"
            ],
            "seeAlso": [
                "ak.wwise.core.workUnit.load"
            ],
            "description": "Unload a Work Unit. No object contained in the Work Unit will be available after this call. If the Work Unit is modified and not saved, the function will return error. The Undo history will be cleared.",
            "argsSchema": {
                "type": "object",
                "properties": {
                    "object": {
                        "$ref": "waapi_definitions.json#/definitions/objectArg",
                        "description": "The ID (GUID), name, or path of the Work Unit to unload."
                    }
                },
                "required": [
                    "object"
                ],
                "additionalProperties": false
            },
            "resultSchema": {
                "type": "object",
                "properties": {},
                "additionalProperties": false
            },
            "optionsSchema": {
                "type": "object",
                "properties": {},
                "additionalProperties": false
            },
            "examples": [
                {
                    "title": "Unload a Work Unit.",
                    "description": "Unload a Work Unit.",
                    "args": {
                        "object": "\\Containers\\myWorkUnit"
                    },
                    "result": {}
                }
            ]
        }
    ],
